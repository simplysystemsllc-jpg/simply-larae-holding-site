# Simply LaRae — Environment Configuration
#
# SITE MODE
# Controls the public homepage.
#
# "coming_soon" → Shows the launch/partnership page (default while pre-launch)
# "full"        → Restores the complete Simply LaRae website
#
# To restore the full site: change the value below to "full" and restart the dev server.
VITE_SITE_MODE=coming_soon

# ── EMAIL (Resend) ──────────────────────────────────────────────────────────
#
# Set RESEND_API_KEY to activate real email delivery via resend.com (free tier).
# Steps:
#   1. Create a free account at https://resend.com using simplylarae.dba@gmail.com
#   2. Go to API Keys → Create API Key
#   3. Paste the key below AND add it to your Vercel project environment variables
#
# On Vercel: Project Settings → Environment Variables → add RESEND_API_KEY
# Without this key, form submissions are logged only (no email sent).
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# Optional — set once your domain (simplylarea.com) is verified in Resend:
# FROM_EMAIL=Simply LaRae <hello@simplylarea.com>
